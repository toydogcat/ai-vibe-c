#!/bin/bash

# AI Vibe C - Startup Script
# Usage: ./run [mode] [options]
# Modes: local, docker

set -e

PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MODE="${1:-local}"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

print_header() {
    echo -e "${BLUE}========================================${NC}"
    echo -e "${BLUE}$1${NC}"
    echo -e "${BLUE}========================================${NC}"
}

print_success() {
    echo -e "${GREEN}✓ $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}⚠ $1${NC}"
}

print_error() {
    echo -e "${RED}✗ $1${NC}"
}

show_help() {
    cat << EOF
AI Vibe C - 启动脚本

用法: ./run [mode] [options]

模式:
  local       - 本地运行 (默认)
              示例: ./run local
  
  docker      - 使用 Docker Compose 运行
              示例: ./run docker

本地模式选项:
  --backend-only      - 仅启动后端
  --frontend-only     - 仅启动前端
  --ngrok-only        - 仅启动 Ngrok 隧道
  --no-install        - 跳过依赖安装
  --build-frontend    - 构建前端生产包
  --deploy-firebase   - 构建前端并部署到 Firebase Hosting
  --ngrok             - 启动前后端并创建 Ngrok 隧道
  --go-backend        - 使用 Go 后端 (默认使用 Python)

Docker 模式选项:
  --build         - 重建镜像
  --detach        - 后台运行
  --logs          - 查看日志
  --stop          - 停止容器
  --down          - 停止并删除容器

示例:
  ./run local                    # 本地启动前后端（显示命令）
  ./run local --backend-only     # 仅启动后端
  ./run local --frontend-only    # 仅启动前端
  ./run local --ngrok-only       # 仅启动 Ngrok 隧道
  ./run local --build-frontend   # 构建前端生产包
  ./run local --deploy-firebase  # 构建并部署到 Firebase Hosting
  ./run local --ngrok            # 启动前后端并创建 Ngrok 隧道
  ./run local --go-backend       # 使用 Go 后端启动
  ./run local --go-backend --ngrok # 使用 Go 后端并创建 Ngrok 隧道
  ./run docker                   # Docker 启动
  ./run docker --build           # Docker 重建并启动
  ./run docker --logs            # 查看 Docker 日志
  ./run docker --down            # 停止 Docker 容器

EOF
}

# Local mode functions
start_local() {
    local backend_only=false
    local frontend_only=false
    local ngrok_only=false
    local no_install=false
    local build_frontend=false
    local deploy_firebase=false
    local ngrok_mode=false
    local go_backend=false
    
    # Parse options
    for arg in "${@:2}"; do
        case $arg in
            --backend-only) backend_only=true ;;
            --frontend-only) frontend_only=true ;;
            --ngrok-only) ngrok_only=true ;;
            --no-install) no_install=true ;;
            --build-frontend) build_frontend=true ;;
            --deploy-firebase) deploy_firebase=true ;;
            --ngrok) ngrok_mode=true ;;
            --go-backend) go_backend=true ;;
        esac
    done

    if [[ "$build_frontend" == true ]]; then
        print_header "构建前端生产包"
        cd "$PROJECT_DIR/frontend"
        if [[ "$no_install" != true ]]; then
            print_warning "安装前端依赖..."
            npm install --silent
            print_success "前端依赖已安装"
        fi
        npm run build
        print_success "前端构建完成：$PROJECT_DIR/frontend/dist"
        return 0
    fi

    if [[ "$deploy_firebase" == true ]]; then
        print_header "部署到 Firebase Hosting"
        cd "$PROJECT_DIR/frontend"
        if [[ "$no_install" != true ]]; then
            print_warning "安装前端依赖..."
            npm install --silent
            print_success "前端依赖已安装"
        fi
        npm run build
        print_success "前端构建完成：$PROJECT_DIR/frontend/dist"
        print_header "执行 Firebase 部署"
        cd "$PROJECT_DIR"
        firebase deploy --only hosting:ai-diy-123
        return 0
    fi

    if [[ "$ngrok_only" == true ]]; then
        print_header "启动 Ngrok 隧道"
        if [[ "$go_backend" == true ]]; then
            print_warning "使用 Go 后端..."
            cd "$PROJECT_DIR/backend/go-backend"
            if [[ "$no_install" != true ]]; then
                print_warning "安装 Go 依赖..."
                go mod download
                print_success "Go 依赖已安装"
            fi
        else
            print_warning "使用 Python 后端..."
            cd "$PROJECT_DIR/backend"
            if [[ "$no_install" != true ]]; then
                print_warning "安装后端依赖..."
                conda run -n toby pip install -q -r requirements.txt
                print_success "后端依赖已安装"
            fi
        fi
        conda run -n toby python ngrok_tunnel.py
        return 0
    fi

    if [[ "$ngrok_mode" == true ]]; then
        print_header "启动前后端服务 + Ngrok 隧道"
        
        # 启动后端
        print_warning "启动后端服务..."
        if [[ "$go_backend" == true ]]; then
            print_warning "使用 Go 后端..."
            cd "$PROJECT_DIR/backend/go-backend"
            if [[ "$no_install" != true ]]; then
                print_warning "安装 Go 依赖..."
                go mod download
                print_success "Go 依赖已安装"
            fi
            
            # 在后台启动 Go 后端
            go run main.go &
            BACKEND_PID=$!
            print_success "Go 后端服务已启动 (PID: $BACKEND_PID)"
        else
            print_warning "使用 Python 后端..."
            cd "$PROJECT_DIR/backend"
            if [[ "$no_install" != true ]]; then
                conda run -n toby pip install -q -r requirements.txt
                print_success "后端依赖已安装"
            fi
            
            # 在后台启动 Python 后端
            conda run -n toby python main.py &
            BACKEND_PID=$!
            print_success "Python 后端服务已启动 (PID: $BACKEND_PID)"
        fi
        
        # 等待后端启动
        sleep 3
        
        # 启动前端
        print_warning "启动前端服务..."
        cd "$PROJECT_DIR/frontend"
        if [[ "$no_install" != true ]]; then
            npm install --silent
            print_success "前端依赖已安装"
        fi
        
        # 在后台启动前端
        npm run dev &
        FRONTEND_PID=$!
        print_success "前端服务已启动 (PID: $FRONTEND_PID)"
        
        # 等待前端启动
        sleep 5
        
        # 启动 Ngrok 隧道
        print_warning "启动 Ngrok 隧道..."
        cd "$PROJECT_DIR/backend"
        conda run -n toby python ngrok_tunnel.py &
        NGROK_PID=$!
        print_success "Ngrok 隧道已启动 (PID: $NGROK_PID)"
        
        print_header "服务启动完成"
        echo -e "${GREEN}前端地址: http://localhost:3000${NC}"
        echo -e "${GREEN}后端地址: http://localhost:8000${NC}"
        if [[ "$go_backend" == true ]]; then
            echo -e "${GREEN}后端类型: Go${NC}"
        else
            echo -e "${GREEN}后端类型: Python${NC}"
            echo -e "${GREEN}API 文档: http://localhost:8000/docs${NC}"
        fi
        echo -e "${GREEN}Ngrok 隧道: 等待显示...${NC}"
        echo ""
        echo -e "${YELLOW}按 Ctrl+C 停止所有服务${NC}"
        
        # 等待用户中断
        trap "echo -e '\n${YELLOW}正在停止服务...${NC}'; kill $BACKEND_PID $FRONTEND_PID $NGROK_PID 2>/dev/null; exit 0" INT
        wait
        return 0
    fi
    
    if [[ "$frontend_only" == true && "$backend_only" != true ]]; then
        print_header "启动前端服务"
        cd "$PROJECT_DIR/frontend"
        if [[ "$no_install" != true ]]; then
            print_warning "安装前端依赖..."
            npm install --silent
            print_success "前端依赖已安装"
        fi
        npm run dev
        return 0
    fi

    if [[ "$backend_only" == true && "$frontend_only" != true ]]; then
        print_header "启动后端服务"
        if [[ "$go_backend" == true ]]; then
            print_warning "使用 Go 后端..."
            cd "$PROJECT_DIR/backend/go-backend"
            if [[ "$no_install" != true ]]; then
                print_warning "安装 Go 依赖..."
                go mod download
                print_success "Go 依赖已安装"
            fi
            go run main.go
        else
            print_warning "使用 Python 后端..."
            cd "$PROJECT_DIR/backend"
            if [[ "$no_install" != true ]]; then
                print_warning "安装后端依赖..."
                conda run -n toby pip install -q -r requirements.txt
                print_success "后端依赖已安装"
            fi
            conda run -n toby python main.py
        fi
        return 0
    fi
    
    if [[ "$frontend_only" != true ]]; then
        print_header "启动后端服务"
        
        if [[ "$go_backend" == true ]]; then
            print_warning "使用 Go 后端..."
            cd "$PROJECT_DIR/backend/go-backend"
            
            if [[ "$no_install" != true ]]; then
                print_warning "安装 Go 依赖..."
                go mod download
                print_success "Go 依赖已安装"
            fi
            
            print_success "Go 后端启动命令已准备"
            echo "在新终端运行此命令："
            echo ""
            echo -e "${BLUE}cd $PROJECT_DIR/backend/go-backend && go run main.go${NC}"
            echo ""
        else
            print_warning "使用 Python 后端..."
            cd "$PROJECT_DIR/backend"
            
            if [[ "$no_install" != true ]]; then
                print_warning "安装后端依赖..."
                conda run -n toby pip install -q -r requirements.txt
                print_success "后端依赖已安装"
            fi
            
            print_success "Python 后端启动命令已准备"
            echo "在新终端运行此命令："
            echo ""
            echo -e "${BLUE}cd $PROJECT_DIR/backend && conda activate toby && python main.py${NC}"
            echo ""
        fi
    fi
    
    if [[ "$backend_only" != true ]]; then
        print_header "启动前端服务"
        
        cd "$PROJECT_DIR/frontend"
        
        if [[ "$no_install" != true ]]; then
            print_warning "安装前端依赖..."
            npm install --silent
            print_success "前端依赖已安装"
        fi
        
        print_success "前端启动命令已准备"
        echo "在新终端运行此命令："
        echo ""
        echo -e "${BLUE}cd $PROJECT_DIR/frontend && npm run dev${NC}"
        echo ""
    fi
    
    print_header "本地启动信息"
    echo -e "${GREEN}前端地址: http://localhost:3000${NC}"
    echo -e "${GREEN}后端地址: http://localhost:8000${NC}"
    echo -e "${GREEN}API 文档: http://localhost:8000/docs${NC}"
}

# Docker mode functions
start_docker() {
    local build=false
    local detach=false
    local logs_mode=false
    local stop_mode=false
    local down_mode=false
    
    # Parse options
    for arg in "${@:2}"; do
        case $arg in
            --build) build=true ;;
            --detach) detach=true ;;
            --logs) logs_mode=true ;;
            --stop) stop_mode=true ;;
            --down) down_mode=true ;;
        esac
    done
    
    cd "$PROJECT_DIR/infra"
    
    # Check if .env exists
    if [[ ! -f .env ]]; then
        print_warning ".env 文件不存在，使用 .env.example 作为模板"
        if [[ -f .env.example ]]; then
            cp .env.example .env
            print_warning "已创建 .env，请编辑后重新运行"
            print_warning "编辑命令: nano $PROJECT_DIR/infra/.env"
            return 1
        fi
    fi
    
    if [[ "$down_mode" == true ]]; then
        print_header "停止并删除容器"
        docker-compose down
        print_success "容器已停止并删除"
        return 0
    fi
    
    if [[ "$stop_mode" == true ]]; then
        print_header "停止容器"
        docker-compose stop
        print_success "容器已停止"
        return 0
    fi
    
    if [[ "$logs_mode" == true ]]; then
        print_header "查看日志"
        docker-compose logs -f
        return 0
    fi
    
    if [[ "$build" == true ]]; then
        print_header "构建镜像"
        docker-compose build --no-cache
        print_success "镜像构建完成"
    fi
    
    print_header "启动 Docker 容器"
    
    if [[ "$detach" == true ]]; then
        docker-compose up -d
        print_success "容器已在后台启动"
        echo ""
        sleep 2
        docker-compose ps
    else
        docker-compose up
    fi
}

# Main
case "$MODE" in
    local)
        start_local "$@"
        ;;
    docker)
        start_docker "$@"
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        print_error "未知模式: $MODE"
        echo ""
        show_help
        exit 1
        ;;
esac
